{
  "openapi": "3.1.0",
  "info": {
    "title": "TechStore API",
    "description": "Backend de la plataforma de e-commerce TechStore. Obtén un token con /api/auth/register o /api/auth/login y úsalo con el botón Authorize para probar los endpoints protegidos.",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    {
      "name": "Usuario — Wishlist y Carrito",
      "description": "Endpoints protegidos: requieren el header Authorization: Bearer <token>. Sin token devuelven 403."
    },
    {
      "name": "Autenticación",
      "description": "Registro e inicio de sesión. Ambos devuelven un token JWT."
    },
    {
      "name": "Productos",
      "description": "Catálogo público: búsqueda con filtros y detalle por ID."
    }
  ],
  "paths": {
    "/api/user/wishlist": {
      "post": {
        "tags": [
          "Usuario — Wishlist y Carrito"
        ],
        "summary": "Agregar producto a la wishlist",
        "operationId": "addWishlist",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductIdRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Agregado (sin cuerpo)"
          },
          "400": {
            "description": "El producto no existe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "Product not found: 99"
                }
              }
            }
          },
          "403": {
            "description": "Sin token o token inválido"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Usuario — Wishlist y Carrito"
        ],
        "summary": "Remover producto de la wishlist",
        "operationId": "removeWishlist",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductIdRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Removido (sin cuerpo)"
          },
          "403": {
            "description": "Sin token o token inválido"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/user/cart": {
      "post": {
        "tags": [
          "Usuario — Wishlist y Carrito"
        ],
        "summary": "Agregar producto al carrito",
        "description": "Si el producto ya está en el carrito, actualiza la cantidad (upsert).",
        "operationId": "addToCart",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CartRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Agregado o actualizado (sin cuerpo)"
          },
          "400": {
            "description": "Cantidad menor a 1 o producto inexistente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "Quantity must be at least 1"
                }
              }
            }
          },
          "403": {
            "description": "Sin token o token inválido"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Usuario — Wishlist y Carrito"
        ],
        "summary": "Remover producto del carrito",
        "operationId": "removeFromCart",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductIdRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Removido (sin cuerpo)"
          },
          "403": {
            "description": "Sin token o token inválido"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": [
          "Autenticación"
        ],
        "summary": "Registrar usuario",
        "description": "Crea una cuenta nueva y devuelve un token JWT listo para usar.",
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Usuario registrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Correo ya registrado o campos inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "Email already registered"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Autenticación"
        ],
        "summary": "Iniciar sesión",
        "description": "Valida las credenciales y devuelve un token JWT.",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "400": {
            "description": "Credenciales inválidas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "Invalid credentials"
                }
              }
            }
          },
          "200": {
            "description": "Login exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "tags": [
          "Productos"
        ],
        "summary": "Detalle de un producto",
        "operationId": "getById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID del producto",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "Producto encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductResponse"
                }
              }
            }
          },
          "400": {
            "description": "El producto no existe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "Product not found: 99"
                }
              }
            }
          }
        }
      }
    },
    "/api/products/search": {
      "get": {
        "tags": [
          "Productos"
        ],
        "summary": "Buscar productos con filtros",
        "description": "Todos los filtros son opcionales y combinables. Sin parámetros devuelve los 20 productos.",
        "operationId": "search",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Busca por nombre (contiene, sin distinguir mayúsculas)",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "pro"
          },
          {
            "name": "brand",
            "in": "query",
            "description": "Busca por marca (contiene, sin distinguir mayúsculas)",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "Apple"
          },
          {
            "name": "minPrice",
            "in": "query",
            "description": "Precio mínimo (inclusive)",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "example": 1000
          },
          {
            "name": "maxPrice",
            "in": "query",
            "description": "Precio máximo (inclusive)",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "example": 6000
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de productos que cumplen los filtros",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProductResponse"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProductIdRequest": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "integer",
            "format": "int64",
            "description": "ID del producto",
            "example": 1
          }
        },
        "required": [
          "productId"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Mensaje de error legible"
          }
        }
      },
      "CartRequest": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "integer",
            "format": "int64",
            "description": "ID del producto",
            "example": 1
          },
          "quantity": {
            "type": "integer",
            "format": "int32",
            "description": "Cantidad deseada (mínimo 1)",
            "example": 2
          }
        },
        "required": [
          "productId",
          "quantity"
        ]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Correo electrónico válido",
            "example": "estudiante@utec.edu.pe"
          },
          "password": {
            "type": "string",
            "description": "Contraseña del usuario",
            "example": "miPassword123"
          },
          "name": {
            "type": "string",
            "description": "Nombre completo del usuario",
            "example": "Juan Pérez"
          }
        },
        "required": [
          "email",
          "name",
          "password"
        ]
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Token JWT. Enviarlo en el header Authorization: Bearer <token>",
            "example": "eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiJlc3R1ZGlhbnRlQHV0ZWMuZWR1LnBlIn0.abc123"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Correo registrado",
            "example": "estudiante@utec.edu.pe"
          },
          "password": {
            "type": "string",
            "description": "Contraseña del usuario",
            "example": "miPassword123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "ProductResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Identificador único del producto",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "Nombre del producto",
            "example": "iPhone 15 Pro"
          },
          "brand": {
            "type": "string",
            "description": "Marca del producto",
            "example": "Apple"
          },
          "price": {
            "type": "number",
            "format": "double",
            "description": "Precio en soles (S/)",
            "example": 5499.0
          },
          "category": {
            "type": "string",
            "description": "Categoría del producto",
            "example": "Smartphones"
          },
          "imageUrl": {
            "type": "string",
            "description": "URL de la imagen del producto",
            "example": "https://via.placeholder.com/150"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}